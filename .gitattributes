# Default handling: auto-detect text files, normalize to LF in repo,
# restore native line endings on checkout.
* text=auto

# --- Shell scripts (Unix execution requires LF) ---
*.sh          text eol=lf
gradlew       text eol=lf

# --- Windows batch files (require CRLF) ---
*.bat         text eol=crlf
*.cmd         text eol=crlf
gradlew.bat   text eol=crlf

# --- JVM sources / build scripts (LF) ---
*.kt          text eol=lf
*.kts         text eol=lf
*.java        text eol=lf
*.gradle      text eol=lf
*.properties  text eol=lf

# --- Resources / config (LF) ---
*.xml         text eol=lf
*.json        text eol=lf
*.yml         text eol=lf
*.yaml        text eol=lf
*.toml        text eol=lf
*.md          text eol=lf
*.txt         text eol=lf

# --- Binary assets (never normalize) ---
*.png         binary
*.jpg         binary
*.jpeg        binary
*.gif         binary
*.webp        binary
*.ico         binary
*.svg         binary
*.pdf         binary
*.jar         binary
*.aar         binary
*.keystore    binary
*.jks         binary
*.apk         binary
*.aab         binary
*.so          binary
*.ttf         binary
*.otf         binary
*.woff        binary
*.woff2       binary
